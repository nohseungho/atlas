# Google OAuth (Blogger API). 실제 값은 .env.local에만 작성하고 절대 커밋하지 않는다.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ATLAS 공식 로컬 포트는 3002로 고정한다 (start-atlas.bat 기준). 아래 값을 그대로 사용한다.
GOOGLE_REDIRECT_URI=http://localhost:3002/api/auth/blogger/callback

# Token Store 암호화 키. AES-256-GCM용 32바이트 키를 base64로 인코딩해서 사용.
# 생성 예시: node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
TOKEN_ENCRYPTION_KEY=
