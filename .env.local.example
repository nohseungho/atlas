# Google OAuth (Blogger API). 실제 값은 .env.local에만 작성하고 절대 커밋하지 않는다.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ATLAS 공식 로컬 포트는 3002로 고정한다 (start-atlas.bat 기준). 아래 값을 그대로 사용한다.
GOOGLE_REDIRECT_URI=http://localhost:3002/api/auth/blogger/callback

# Token Store 암호화 키. AES-256-GCM용 32바이트 키를 base64로 인코딩해서 사용.
# 생성 예시: node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
TOKEN_ENCRYPTION_KEY=

# ─── Revenue Automation R2 (선택) ────────────────────────────────────────────
# 아래 키가 없으면 관련 기능은 코드에 비밀값을 넣지 않고 NEEDS_CONFIGURATION 상태로만 표시된다.
# 자동 원고 생성용 AI 키 (하나만 있으면 됨). 없으면 자동 본문 생성은 차단되고 Factory MASTER만 인정.
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
ATLAS_AI_API_KEY=
# 공식 자료 조사용 검색 API 키. 없으면 research 단계가 NEEDS_CONFIGURATION.
ATLAS_SEARCH_API_KEY=

# 제휴 네트워크 read-only 실적 동기화 (server-only). 없으면 공식 CSV 리포트 import fallback 사용.
IMPACT_ACCOUNT_SID=
IMPACT_AUTH_TOKEN=
VISITORS_COVERAGE_API_KEY=

# 공개 추적 endpoint base (예: https://track.example.com/r). 확인된 실제 endpoint만 입력.
# 비어 있으면 캠페인 링크는 BLOCKED_PUBLIC_TRACKING_ENDPOINT로 표시된다.
ATLAS_PUBLIC_TRACKING_BASE=
